# ─────────────────────────────────────────────────────────────────────────────
# Feuerwehr Portal — Umgebungsvariablen
# Kopiere als .env und trage deine Werte ein: cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=nocodb
POSTGRES_PASSWORD=CHANGEME_postgres_password
POSTGRES_DB=nocodb

# PostgREST
POSTGREST_DB_PASSWORD=CHANGEME_postgrest_password
JWT_SECRET=CHANGEME_min_32_chars_jwt_secret_here

# Ports (Host-Ports)
PORTAL_PORT=8180
UPTIME_PORT=3001

# FoodBot
FOODBOT_ADMIN_PASSWORD=CHANGEME_foodbot_admin_password
